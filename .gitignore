.superpowers/
.worktrees/
.direnv/
.claude/

# Nix build result
result

# Rust build artifacts
target/

# Populated by `flake.nix`'s devShell as a symlink into the libopus
# flake input — see `crates/sunset-voice/build.rs`. Not tracked in
# git; the canonical pin lives in `flake.lock` (`libopus` input).
vendor/

# `desktop/dist` is populated by the flake's `sunset-desktop` build
# phase (and the dev-shell hook) as a copy of the Nix-built `webDist`.
# Never source-of-truth: regenerated on every dev-shell entry and Nix
# build, so tracking it would just churn the working tree. No trailing
# slash — the dev-shell hook materializes it as a symlink to the Nix
# store, and gitignore's directory-only `foo/` form doesn't match
# symlinks. The `**/` prefix catches the case where the dev shell is
# entered from a subdirectory (e.g. `nix develop` invoked from `web/`),
# which materializes the symlink at `<cwd>/desktop/dist`.
**/desktop/dist

# `desktop/gen/` is regenerated by `tauri-build` on every cargo build —
# Tauri-derived config schema, capability scaffolding, etc.
desktop/gen/

# Bake stamp left by `desktop/scripts/bake-icons.sh` to avoid redundant
# re-renders. The icon PNG/ICO/ICNS outputs themselves are committed.
desktop/icons/.bake-stamp

# Per-run artifacts written by the `review-fix-loop` / `overnight-cleanup`
# skills. Mirrored to `~/.claude/overnight-runs/` for durable storage;
# the in-tree copy is just scratch.
.review-fix-loop/
